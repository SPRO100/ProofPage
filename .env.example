# ─────────────────────────────────────────────
# Supabase — required
# ─────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key — server-side only, never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─────────────────────────────────────────────
# App
# ─────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─────────────────────────────────────────────
# Feature flags
# Both default to false. Only exact string "true" enables them.
# Do not enable billing before completing the security audit.
# ─────────────────────────────────────────────
BILLING_ENABLED=false
REVENUE_VERIFICATION_ENABLED=false

# ─────────────────────────────────────────────
# Cron
# Random secret used to protect /api/cron/* endpoints.
# Generate with: openssl rand -hex 32
# To re-enable cron, set REVENUE_VERIFICATION_ENABLED=true and restore
# vercel.json: { "crons": [{ "path": "/api/cron/sync-revenue", "schedule": "0 * * * *" }] }
# ─────────────────────────────────────────────
CRON_SECRET=your-cron-secret

# ─────────────────────────────────────────────
# Billing — Stripe (Europe / international)
# Disabled — do not configure before billing security audit
# ─────────────────────────────────────────────
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_PRO_PRICE_ID=price_...

# ─────────────────────────────────────────────
# Billing — ЮKassa (Russia)
# Disabled — do not configure before billing security audit
# ─────────────────────────────────────────────
# YUKASSA_SHOP_ID=your-shop-id
# YUKASSA_SECRET_KEY=your-secret-key
# YUKASSA_WEBHOOK_SECRET=your-webhook-secret
# YUKASSA_PRO_AMOUNT_RUB=990.00

# ─────────────────────────────────────────────
# Billing — NOWPayments (crypto)
# Disabled — do not configure before billing security audit
# ─────────────────────────────────────────────
# NOWPAYMENTS_API_KEY=your-api-key
# NOWPAYMENTS_IPN_SECRET=your-ipn-secret
# NOWPAYMENTS_PRO_AMOUNT_USD=9.99

# ─────────────────────────────────────────────
# Revenue providers — credentials stored in Supabase Vault per user.
# No global API keys needed here — each founder connects their own account.
# Disabled — do not configure before billing security audit
# ─────────────────────────────────────────────
