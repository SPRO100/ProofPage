# ─────────────────────────────────────────────
# Supabase — required
# ─────────────────────────────────────────────
# Found in: Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key — server-side only, never expose to the browser.
# Found in: Supabase dashboard → Project Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─────────────────────────────────────────────
# Cron
# ─────────────────────────────────────────────
# Random secret used by Vercel Cron to call /api/cron/* securely.
# Generate with: openssl rand -hex 32
CRON_SECRET=your-cron-secret

# ─────────────────────────────────────────────
# Billing — add when starting Phase 7 (billing)
# ─────────────────────────────────────────────
# Stripe (Europe / international)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ЮKassa (Russia)
# YUKASSA_SHOP_ID=your-shop-id
# YUKASSA_SECRET_KEY=your-secret-key
# YUKASSA_WEBHOOK_SECRET=your-webhook-secret

# NOWPayments (crypto)
# NOWPAYMENTS_API_KEY=your-api-key
# NOWPAYMENTS_IPN_SECRET=your-ipn-secret

# ─────────────────────────────────────────────
# Revenue providers — credentials stored in Supabase Vault per user.
# No global API keys needed here — each founder connects their own account.
# ─────────────────────────────────────────────

# ─────────────────────────────────────────────
# App
# ─────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
